"""
Ortam Değişkenleri Yapılandırması
.env dosyasına kopyala
"""

# Flask Ayarları
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# Veritabanı
DATABASE_URL=mssql+pyodbc://username:password@server/database_name?driver=ODBC+Driver+17+for+SQL+Server

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# CORS (Frontend URL'leri)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Backup Ayarları
BACKUP_PATH=C:\\Backups\\FinancialTracking\\
